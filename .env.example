# Server
NODE_ENV=production
PORT=5000
BACKEND_PORT=5000
FRONTEND_PORT=3000

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=coffee123
MONGODB_URI=mongodb://admin:coffee123@mongodb:27017/coffee_pos?authSource=admin

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Vite (frontend build args)
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Google Drive OAuth (for backup)
# Create OAuth2 credentials at: https://console.cloud.google.com/apis/credentials
# Enable Google Drive API for your project
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/backups/auth/callback

# Backup
BACKUP_DIR=/tmp/coffee-pos-backups
